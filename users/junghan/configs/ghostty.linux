# Ghostty configuration for Linux/NixOS
# font-family = D2CodingLigature Nerd Font
font-family = Monoplex Nerd
font-size = 14.0

term = xterm-ghostty

# Scrollback buffer limit (1MB instead of default 10MB)
# Reduces memory usage and improves performance with long Claude Code sessions
scrollback-limit = 1000000

# Window decoration: server = WM manages borders (i3 child-border works)
window-decoration = server

# 윈도우 패딩 (좌/우)
window-padding-x = 10,10

# 윈도우 패딩 (상/하)
window-padding-y = 10,10

# shell integration : none
shell-integration = none
shell-integration-features = cursor, sudo, no-title

# 창, pane 등을 닫을 때 확인창을 표시하지 않음.
confirm-close-surface = true

# 마우스 스크롤 멀티플라리어
mouse-scroll-multiplier = 0.7

# 투명도 설정 : 95%
background-opacity = 0.85
background-blur-radius = 20
mouse-hide-while-typing = true

# Clipboard settings
clipboard-paste-protection = false
copy-on-select = clipboard

# Theme
theme = Dracula

keybind = alt+u=scroll_page_fractional:-0.5
keybind = alt+v=scroll_page_fractional:0.5
