# Forgejo (forge.junghanacs.com) — Oracle 운영용 환경변수
# 실제 .env 파일은 docker-compose.yml과 같은 디렉토리에 두고 git ignore.
#
# 생성 명령:
#   openssl rand -base64 32   # 각 변수마다 별도 값
#
# 작성 후:
#   docker compose up -d
#   → 첫 boot 시 /data/forgejo/conf/app.ini 자동 생성
#   → https://forge.junghanacs.com/ 접속 → setup wizard 통과 (SETUP.org 참고)

# PostgreSQL password — forge-db 컨테이너용
FORGE_DB_PASSWORD=
